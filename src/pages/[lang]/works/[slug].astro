---
import { getCollection, type CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Meta from '../../../components/Meta.astro';
import { t, isLocale, type Locale } from '../../../lib/i18n';

export async function getStaticPaths() {
  const projects = await getCollection('projects', ({ data }) => !data.draft);
  return projects.map((entry) => {
    const cleanSlug = entry.data.urlSlug.replace(/^(es|en)-/, '');
    const lang = entry.data.lang;
    return {
      params: { lang, slug: cleanSlug },
      props: { entry },
    };
  });
}

interface Props {
  entry: CollectionEntry<'projects'>;
}

const { entry } = Astro.props;
const { lang: rawLang } = Astro.params;

if (!isLocale(rawLang)) {
  throw new Error(`Invalid locale: ${rawLang}`);
}
const lang: Locale = rawLang;

const { Content } = await entry.render();

const allInLang = await getCollection('projects', ({ data }) =>
  data.lang === lang && !data.draft
);
allInLang.sort((a, b) => a.data.number - b.data.number);
const currentIdx = allInLang.findIndex((p) => p.data.urlSlug === entry.data.urlSlug);
const nextEntry = allInLang[(currentIdx + 1) % allInLang.length];
const nextSlug = nextEntry.data.urlSlug.replace(/^(es|en)-/, '');

const copy = {
  es: {
    heroLabel: '05 / Caso',
    overviewLabel: 'Resumen',
    stackLabel: 'Stack',
    linksLabel: 'Enlaces',
    galleryLabel: 'Galería',
    nextLabel: 'Siguiente proyecto',
    liveLabel: 'Ver proyecto',
    repoLabel: 'Ver código',
    dashboardLabel: 'Panel operativo',
    phoneLabel: 'WhatsApp en vivo',
    calendarLabel: 'Calendario sincronizado',
    phoneIntroTitle: 'Interfaz conversacional, no app nueva',
    phoneIntroCopy:
      'La reserva sucede dentro de WhatsApp. El teléfono aquí funciona como prueba de producto: el cliente escribe natural, el sistema entiende, valida y responde sin sacarlo del canal.',
    posHeroLabel: 'Suite híbrida',
    posHeroTitle: 'Caja principal, interfaz operativa y reportes en un solo sistema.',
    posHeroCopy:
      'POS Tree Codes unifica la operación de caja, la lectura del negocio y la capa fiscal en una experiencia pensada para uso real, no para demo genérica.',
    posInterfaceLabel: 'Interfaz operativa',
    posPrimaryLabel: 'Cliente de escritorio',
    posSecondaryLabel: 'Reportes ejecutivos',
    posTertiaryLabel: 'Operación fiscal',
    hubHeroLabel: 'Launcher seguro',
    hubHeroTitle: 'Instalación, actualización y control desde un solo punto.',
    hubHeroCopy:
      'TreeCodes Hub concentra el ciclo de vida del software desktop del ecosistema: qué puede usar el cliente, qué versión está aprobada y cuándo debe bloquearse el acceso.',
    hubPrimaryLabel: 'Panel principal',
    hubSecondaryLabel: 'Pantalla de carga',
    auraHeroLabel: 'Catálogo de marca',
    auraHeroTitle: 'Producto, atmósfera y compra desde una sola pieza visual.',
    auraHeroCopy:
      'Aura Pura necesitaba una presencia digital que vendiera por sensibilidad visual antes que por complejidad técnica: catálogo, detalle de fragancias y administración simple para el negocio.',
    auraPrimaryLabel: 'Vista principal',
    auraSecondaryLabel: 'Producto destacado',
    auraModalLabel: 'Detalle modal',
    auraVideoLabel: 'Funcionamiento',
    licenseHeroLabel: 'Panel de operaciones',
    licenseHeroTitle: 'Licencias, tenants y dispositivos desde un solo sistema.',
    licenseHeroCopy:
      'License Manager centraliza el ciclo de vida de cada cliente: provisioning multi-tenant, autorización de hardware y auditoría completa de accesos, todo bajo seguridad por capas.',
    licensePrimaryLabel: 'Crear licencia',
    licenseSecondaryLabel: 'Detalle de licencia',
    licenseTertiaryLabel: 'Planes',
  },
  en: {
    heroLabel: '05 / Case',
    overviewLabel: 'Overview',
    stackLabel: 'Stack',
    linksLabel: 'Links',
    galleryLabel: 'Gallery',
    nextLabel: 'Next project',
    liveLabel: 'View project',
    repoLabel: 'View code',
    dashboardLabel: 'Operational dashboard',
    phoneLabel: 'Live WhatsApp flow',
    calendarLabel: 'Synchronized calendar',
    phoneIntroTitle: 'Conversational interface, not a new app',
    phoneIntroCopy:
      'Booking happens inside WhatsApp. The phone here acts as product proof: the customer writes naturally, the system understands, validates, and replies without moving them to another channel.',
    posHeroLabel: 'Hybrid suite',
    posHeroTitle: 'Main checkout, operational interface, and reporting in one system.',
    posHeroCopy:
      'POS Tree Codes combines checkout operations, business visibility, and the tax layer into an experience designed for real usage, not a generic product demo.',
    posInterfaceLabel: 'Operational interface',
    posPrimaryLabel: 'Desktop client',
    posSecondaryLabel: 'Executive reports',
    posTertiaryLabel: 'Tax operation',
    hubHeroLabel: 'Secure launcher',
    hubHeroTitle: 'Installation, updates, and control from a single point.',
    hubHeroCopy:
      'TreeCodes Hub centralizes the lifecycle of desktop software across the ecosystem: what the client can use, which version is approved, and when access must be disabled.',
    hubPrimaryLabel: 'Main panel',
    hubSecondaryLabel: 'Loading screen',
    auraHeroLabel: 'Brand catalog',
    auraHeroTitle: 'Product, atmosphere, and purchase in one visual system.',
    auraHeroCopy:
      'Aura Pura needed a digital presence that sold through visual sensitivity before technical complexity: catalog, fragrance detail, and simple administration for the business.',
    auraPrimaryLabel: 'Main view',
    auraSecondaryLabel: 'Featured product',
    auraModalLabel: 'Detail modal',
    auraVideoLabel: 'Flow',
    licenseHeroLabel: 'Operations panel',
    licenseHeroTitle: 'Licenses, tenants, and devices from a single system.',
    licenseHeroCopy:
      'License Manager centralizes each client lifecycle: multi-tenant provisioning, hardware authorization, and full access auditing — all under layered security.',
    licensePrimaryLabel: 'Create license',
    licenseSecondaryLabel: 'License detail',
    licenseTertiaryLabel: 'Plans',
  },
}[lang];

const categoryLabels: Record<string, { es: string; en: string }> = {
  'web-app': { es: 'Web app', en: 'Web app' },
  landing: { es: 'Landing', en: 'Landing' },
  'brand-web': { es: 'Brand web', en: 'Brand web' },
  api: { es: 'API', en: 'API' },
  tool: { es: 'Tool', en: 'Tool' },
};

function formatCategory(category: string) {
  return categoryLabels[category]?.[lang] ?? category.replace('-', ' ');
}

const stackGroups = [
  { label: 'Frontend', items: entry.data.stack.frontend ?? [] },
  { label: 'Backend', items: entry.data.stack.backend ?? [] },
  { label: 'Infra', items: entry.data.stack.infra ?? [] },
].filter((group) => group.items.length > 0);
const heroStats = [
  { label: t('meta.year', lang), value: entry.data.year },
  { label: t('meta.role', lang), value: entry.data.role.slice(0, 2).join(' · ') },
  { label: copy.stackLabel, value: stackGroups.map((group) => group.label).join(' · ') },
];
const showcase = entry.data.showcase;
const showcaseLayout = showcase?.layout ?? (showcase?.phoneVideo ? 'agenda' : showcase?.heroVideo ? 'pos' : undefined);
const isAgendaShowcase = showcaseLayout === 'agenda';
const isPosShowcase = showcaseLayout === 'pos';
const isHubShowcase = showcaseLayout === 'hub';
const isAuraShowcase = showcaseLayout === 'aura';
const isLicenseShowcase = showcaseLayout === 'license';
---

<BaseLayout title={entry.data.title} description={entry.data.description} lang={lang}>
  <section class="hero" data-page-hero>
    <div class="hero-head">
      <p class="section-kicker" data-hero-kicker>{copy.heroLabel}</p>
      <Meta
        items={[
          String(entry.data.number).padStart(2, '0'),
          formatCategory(entry.data.category),
          entry.data.year,
        ]}
        class="hero-meta"
        data-hero-meta
      />
    </div>

    <div class="hero-grid">
      <div class="hero-copy">
        <h1 data-hero-title>{entry.data.title}</h1>
        <p class="hero-description" data-hero-copy>{entry.data.description}</p>

        <div class="hero-links" data-hero-copy>
          {entry.data.url && (
            <a href={entry.data.url} target="_blank" rel="noopener" class="hero-link is-primary">
              {copy.liveLabel}
            </a>
          )}
          {entry.data.repo && (
            <a href={entry.data.repo} target="_blank" rel="noopener" class="hero-link">
              {copy.repoLabel}
            </a>
          )}
        </div>

        <div class="hero-strip" data-hero-copy>
          {heroStats.map((item) => (
            <div class="hero-strip-item">
              <span>{item.label}</span>
              <strong>{item.value}</strong>
            </div>
          ))}
        </div>
      </div>

      <aside class="hero-facts" data-hero-card>
        <div class="fact-card">
          <span class="fact-label">{copy.overviewLabel}</span>
          <div class="fact-group">
            <p>{t('meta.year', lang)}</p>
            <span>{entry.data.year}</span>
          </div>
          <div class="fact-group">
            <p>{t('meta.role', lang)}</p>
            <span>{entry.data.role.join(' · ')}</span>
          </div>
          {entry.data.client && (
            <div class="fact-group">
              <p>{t('meta.client', lang)}</p>
              <span>{entry.data.client}</span>
            </div>
          )}
        </div>

        <div class="fact-card">
          <span class="fact-label">{copy.stackLabel}</span>
          <div class="stack-groups">
            {stackGroups.map((group) => (
              <div class="fact-group">
                <p>{group.label}</p>
                <span>{group.items.join(' · ')}</span>
              </div>
            ))}
          </div>
        </div>

        {(entry.data.url || entry.data.repo) && (
          <div class="fact-card">
            <span class="fact-label">{copy.linksLabel}</span>
            <div class="fact-links">
              {entry.data.url && (
                <a href={entry.data.url} target="_blank" rel="noopener">
                  {copy.liveLabel}
                </a>
              )}
              {entry.data.repo && (
                <a href={entry.data.repo} target="_blank" rel="noopener">
                  {copy.repoLabel}
                </a>
              )}
            </div>
          </div>
        )}
      </aside>
    </div>
  </section>

  <section class="hero-media" data-reveal="scale">
    {isAgendaShowcase ? (
      <div class="showcase-hero">
        <div class="showcase-phone-hero" data-parallax="8">
          <div class="showcase-phone-copy">
            <span class="showcase-label">{copy.phoneLabel}</span>
            <h2>{copy.phoneIntroTitle}</h2>
            <p>{copy.phoneIntroCopy}</p>
            <div class="showcase-phone-points">
              <span>WhatsApp Cloud API</span>
              <span>Claude AI</span>
              <span>Google Calendar API</span>
            </div>
          </div>

          <div class="phone-stage is-hero">
            <div class="phone-glow"></div>
            <div class="phone-frame">
              <div class="phone-notch"></div>
              <div class="phone-screen">
                <video autoplay loop muted playsinline webkit-playsinline preload="auto">
                  <source src={showcase.phoneVideo} type="video/mp4" />
                </video>
              </div>
            </div>
          </div>
        </div>
      </div>
    ) : isPosShowcase ? (
      <div class="showcase-hero showcase-hero-pos">
        <div class="showcase-pos-hero" data-parallax="8">
          <div class="showcase-pos-copy">
            <span class="showcase-label">{copy.posHeroLabel}</span>
            <h2>{copy.posHeroTitle}</h2>
            <p>{copy.posHeroCopy}</p>
            <div class="showcase-phone-points">
              <span>Java 21 Swing</span>
              <span>Spring Boot</span>
              <span>Facturación CR</span>
            </div>
          </div>

          <div class="showcase-pos-video">
            <video autoplay loop muted playsinline webkit-playsinline preload="auto">
              <source src={showcase?.heroVideo} type="video/mp4" />
            </video>
          </div>
        </div>
      </div>
    ) : isHubShowcase ? (
      <div class="showcase-hero showcase-hero-pos">
        <div class="showcase-pos-hero" data-parallax="8">
          <div class="showcase-pos-copy">
            <span class="showcase-label">{copy.hubHeroLabel}</span>
            <h2>{copy.hubHeroTitle}</h2>
            <p>{copy.hubHeroCopy}</p>
            <div class="showcase-phone-points">
              <span>Java 21 Swing</span>
              <span>Spring Boot</span>
              <span>Firma digital</span>
            </div>
          </div>

          <div class="showcase-pos-video">
            <video autoplay loop muted playsinline webkit-playsinline preload="auto">
              <source src={showcase?.heroVideo} type="video/mp4" />
            </video>
          </div>
        </div>
      </div>
    ) : isAuraShowcase ? (
      <div class="showcase-hero showcase-hero-pos">
        <div class="showcase-pos-hero showcase-aura-hero" data-parallax="8">
          <div class="showcase-pos-copy">
            <span class="showcase-label">{copy.auraHeroLabel}</span>
            <h2>{copy.auraHeroTitle}</h2>
            <p>{copy.auraHeroCopy}</p>
            <div class="showcase-phone-points">
              <span>Flask</span>
              <span>Jinja</span>
              <span>Admin Desktop</span>
            </div>
          </div>

          <div class="showcase-pos-video showcase-aura-video">
            <video autoplay loop muted playsinline webkit-playsinline preload="auto">
              <source src={showcase?.heroVideo} type="video/mp4" />
            </video>
          </div>
        </div>
      </div>
    ) : isLicenseShowcase ? (
      <div class="showcase-hero showcase-hero-pos">
        <div class="showcase-pos-hero" data-parallax="8">
          <div class="showcase-pos-copy">
            <span class="showcase-label">{copy.licenseHeroLabel}</span>
            <h2>{copy.licenseHeroTitle}</h2>
            <p>{copy.licenseHeroCopy}</p>
            <div class="showcase-phone-points">
              <span>ASP.NET Core 9</span>
              <span>Clean Architecture</span>
              <span>Multi-tenant MySQL</span>
            </div>
          </div>

          <div class="showcase-pos-video showcase-license-hero">
            <img src={showcase?.primaryImage} alt={entry.data.title} loading="eager" />
          </div>
        </div>
      </div>
    ) : entry.data.cover ? (
      <div class="cover-frame" data-parallax="8">
        <div class="cover-meta">
          <span>{formatCategory(entry.data.category)}</span>
          <span>{entry.data.client ?? entry.data.title}</span>
        </div>
        <Image
          src={entry.data.cover}
          alt={entry.data.title}
          widths={[720, 1080, 1440, 1800]}
          sizes="100vw"
        />
      </div>
    ) : (
      <div class="cover-placeholder" />
    )}
  </section>

  <section class="content" data-reveal="fade">
    <div class="content-shell">
      <aside class="content-rail" data-reveal="fade-up">
        <p class="section-kicker">{copy.overviewLabel}</p>
        <p class="rail-copy">{entry.data.description}</p>
      </aside>

      <article class="prose" data-reveal="fade-up">
        <Content />
      </article>
    </div>
  </section>

  {isAgendaShowcase && (
    <section class="showcase-flow">
      <div class="showcase-flow-head">
        <p class="section-kicker" data-reveal="fade-up">{copy.dashboardLabel}</p>
      </div>

      <div class="showcase-flow-grid" data-stagger-group>
        <div class="showcase-main cover-frame" data-stagger-item data-parallax="5">
          <div class="cover-meta">
            <span>{copy.dashboardLabel}</span>
            <span>{entry.data.client ?? entry.data.title}</span>
          </div>
          <img src={showcase.dashboardImage} alt={`${entry.data.title} dashboard`} loading="lazy" />
        </div>

        <div class="showcase-calendar-shell" data-stagger-item data-parallax="4">
          <div class="tablet-stage">
            <div class="tablet-glow"></div>
            <div class="tablet-frame">
              <div class="tablet-camera"></div>
              <div class="tablet-screen">
                <video autoplay loop muted playsinline webkit-playsinline preload="auto">
                  <source src={showcase.calendarVideo} type="video/mp4" />
                </video>
              </div>
              <div class="tablet-home-bar"></div>
            </div>
          </div>
          <div class="showcase-panel-meta">
            <span>{copy.calendarLabel}</span>
            <span>{entry.data.stack.infra?.[2] ?? 'Google Calendar API'}</span>
          </div>
        </div>
      </div>

      <div class="calendar-preview" aria-hidden="true">
        <div class="calendar-preview-backdrop"></div>
        <div class="calendar-preview-shell">
          <div class="tablet-stage is-preview">
            <div class="tablet-glow"></div>
            <div class="tablet-frame">
              <div class="tablet-camera"></div>
              <div class="tablet-screen">
                <video autoplay loop muted playsinline webkit-playsinline preload="auto">
                  <source src={showcase.calendarVideo} type="video/mp4" />
                </video>
              </div>
              <div class="tablet-home-bar"></div>
            </div>
          </div>
          <div class="showcase-panel-meta">
            <span>{copy.calendarLabel}</span>
            <span>{entry.data.stack.infra?.[2] ?? 'Google Calendar API'}</span>
          </div>
        </div>
      </div>

    </section>
  )}

  {isPosShowcase && (
    <section class="showcase-flow showcase-flow-pos">
      <div class="showcase-flow-head">
        <p class="section-kicker" data-reveal="fade-up">{copy.dashboardLabel}</p>
      </div>

      <div class="showcase-pos-stack" data-stagger-group>
        <div class="showcase-pos-card showcase-pos-card-video" data-stagger-item data-parallax="4">
          <div class="cover-meta">
            <span>{copy.posInterfaceLabel}</span>
            <span>Spring Boot · Java Swing</span>
          </div>
          <div class="showcase-pos-video-shell">
            <video autoplay loop muted playsinline webkit-playsinline preload="auto">
              <source src={showcase?.heroVideo} type="video/mp4" />
            </video>
          </div>
        </div>

        <div class="showcase-pos-grid">
          <div class="showcase-pos-card showcase-pos-card-main" data-stagger-item data-parallax="5">
          <div class="cover-meta">
            <span>{copy.posPrimaryLabel}</span>
            <span>{entry.data.title}</span>
          </div>
          <div class="showcase-pos-media is-device">
            <img src={showcase?.primaryImage} alt={`${entry.data.title} main interface`} loading="lazy" />
          </div>
        </div>

          <div class="showcase-pos-card showcase-pos-card-side" data-stagger-item data-parallax="3">
            <div class="cover-meta">
              <span>{copy.posSecondaryLabel}</span>
              <span>{entry.data.stack.backend?.[1] ?? 'MySQL 8'}</span>
            </div>
            <div class="showcase-pos-media is-report">
              <img src={showcase?.secondaryImage} alt={`${entry.data.title} reports`} loading="lazy" />
            </div>
          </div>

          {entry.data.gallery?.[0] && (
            <div class="showcase-pos-card showcase-pos-card-tertiary" data-stagger-item data-parallax="2">
              <div class="cover-meta">
                <span>{copy.posTertiaryLabel}</span>
                <span>{entry.data.stack.infra?.[0] ?? 'DGT API'}</span>
              </div>
              <div class="showcase-pos-media is-report">
                <Image
                  src={entry.data.gallery[0]}
                  alt={`${entry.data.title} tax operation`}
                  widths={[720, 1080, 1440]}
                  sizes="100vw"
                />
              </div>
            </div>
          )}
        </div>
      </div>
    </section>
  )}

  {isHubShowcase && (
    <section class="showcase-flow showcase-flow-pos">
      <div class="showcase-flow-head">
        <p class="section-kicker" data-reveal="fade-up">{copy.dashboardLabel}</p>
      </div>

      <div class="showcase-pos-stack" data-stagger-group>
        <div class="showcase-pos-card showcase-pos-card-video" data-stagger-item data-parallax="4">
          <div class="cover-meta">
            <span>{copy.hubHeroLabel}</span>
            <span>{entry.data.title}</span>
          </div>
          <div class="showcase-pos-video-shell">
            <video autoplay loop muted playsinline webkit-playsinline preload="auto">
              <source src={showcase?.heroVideo} type="video/mp4" />
            </video>
          </div>
        </div>

        <div class="showcase-pos-grid">
          <div class="showcase-pos-card showcase-pos-card-main" data-stagger-item data-parallax="5">
            <div class="cover-meta">
              <span>{copy.hubPrimaryLabel}</span>
              <span>{entry.data.title}</span>
            </div>
            <div class="showcase-pos-media is-device">
              <img src={showcase?.primaryImage} alt={`${entry.data.title} main panel`} loading="lazy" />
            </div>
          </div>

          <div class="showcase-pos-card showcase-pos-card-side" data-stagger-item data-parallax="3">
            <div class="cover-meta">
              <span>{copy.hubSecondaryLabel}</span>
              <span>{entry.data.stack.backend?.[0] ?? 'Spring Boot'}</span>
            </div>
            <div class="showcase-pos-media is-report is-loading-shot">
              <img src={showcase?.secondaryImage} alt={`${entry.data.title} loading screen`} loading="lazy" />
            </div>
          </div>
        </div>
      </div>
    </section>
  )}

  {isAuraShowcase && (
    <section class="showcase-flow showcase-flow-pos">
      <div class="showcase-flow-head">
        <p class="section-kicker" data-reveal="fade-up">{copy.dashboardLabel}</p>
      </div>

      <div class="showcase-pos-stack" data-stagger-group>
        <div class="showcase-pos-card showcase-pos-card-video" data-stagger-item data-parallax="4">
          <div class="cover-meta">
            <span>{copy.auraVideoLabel}</span>
            <span>{entry.data.title}</span>
          </div>
          <div class="showcase-pos-video-shell">
            <video autoplay loop muted playsinline webkit-playsinline preload="auto">
              <source src={showcase?.heroVideo} type="video/mp4" />
            </video>
          </div>
        </div>

        <div class="showcase-pos-grid">
          <div class="showcase-pos-card showcase-pos-card-main" data-stagger-item data-parallax="5">
            <div class="cover-meta">
              <span>{copy.auraPrimaryLabel}</span>
              <span>{entry.data.title}</span>
            </div>
            <div class="showcase-pos-media is-device is-aura-panel">
              <img src={showcase?.primaryImage} alt={`${entry.data.title} main view`} loading="lazy" />
            </div>
          </div>

          <div class="showcase-pos-card showcase-pos-card-side" data-stagger-item data-parallax="3">
            <div class="cover-meta">
              <span>{copy.auraSecondaryLabel}</span>
              <span>{entry.data.stack.frontend?.[0] ?? 'Flask/Jinja'}</span>
            </div>
            <div class="showcase-pos-media is-report is-aura-product">
              <img src={showcase?.secondaryImage} alt={`${entry.data.title} featured product`} loading="lazy" />
            </div>
          </div>
        </div>
      </div>
    </section>
  )}

  {isLicenseShowcase && (
    <section class="showcase-flow showcase-flow-pos">
      <div class="showcase-flow-head">
        <p class="section-kicker" data-reveal="fade-up">{copy.dashboardLabel}</p>
      </div>

      <div class="showcase-pos-stack" data-stagger-group>
        <div class="showcase-pos-card showcase-pos-card-video" data-stagger-item data-parallax="4">
          <div class="cover-meta">
            <span>{copy.licensePrimaryLabel}</span>
            <span>{entry.data.title}</span>
          </div>
          <div class="showcase-pos-video-shell showcase-license-shell">
            <img src={showcase?.primaryImage} alt={`${entry.data.title} — crear licencia`} loading="lazy" />
          </div>
        </div>

        <div class="showcase-pos-grid">
          <div class="showcase-pos-card showcase-pos-card-main" data-stagger-item data-parallax="5">
            <div class="cover-meta">
              <span>{copy.licenseSecondaryLabel}</span>
              <span>{entry.data.title}</span>
            </div>
            <div class="showcase-pos-media is-device is-license-panel">
              <img src={showcase?.secondaryImage} alt={`${entry.data.title} — detalle`} loading="lazy" />
            </div>
          </div>

