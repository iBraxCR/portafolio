<script>
  const showcaseVideos = document.querySelectorAll('.phone-screen video, .tablet-screen video');

  for (const video of showcaseVideos) {
    const shell = video.closest('.phone-screen, .tablet-screen');
    if (!(shell instanceof HTMLElement) || !(video instanceof HTMLVideoElement)) continue;

    const source = video.currentSrc || video.querySelector('source')?.src || '';
    const storageKey = source ? `showcase-frame:${source}` : '';
    const debugLabel = shell.classList.contains('phone-screen') ? 'agenda-phone' : 'agenda-tablet';

    const applyFallback = (dataUrl) => {
      if (!dataUrl) return;
      shell.style.backgroundImage = `url("${dataUrl}")`;
      shell.style.backgroundSize = 'contain';
      shell.style.backgroundPosition = 'center';
      shell.style.backgroundRepeat = 'no-repeat';
      console.log(`[${debugLabel}] fallback applied`);
    };

    if (storageKey) {
      try {
        const cached = sessionStorage.getItem(storageKey);
        console.log(`[${debugLabel}] cached frame`, cached ? 'hit' : 'miss');
        if (cached) applyFallback(cached);
      } catch {}
    }

    const tryPlay = () => {
      console.log(`[${debugLabel}] tryPlay`, {
        readyState: video.readyState,
        currentTime: video.currentTime,
        paused: video.paused,
        ended: video.ended,
      });
      const promise = video.play();
      if (promise && typeof promise.catch === 'function') {
        promise.catch((error) => {
          console.log(`[${debugLabel}] play rejected`, error?.message ?? error);
        });
      }
    };

    const captureFrame = () => {
      if (!storageKey || !video.videoWidth || !video.videoHeight) return;

      try {
        console.log(`[${debugLabel}] captureFrame`, {
          width: video.videoWidth,
          height: video.videoHeight,
        });
        const maxWidth = shell.classList.contains('phone-screen') ? 360 : 960;
        const scale = Math.min(1, maxWidth / video.videoWidth);
        const canvas = document.createElement('canvas');
        canvas.width = Math.max(1, Math.round(video.videoWidth * scale));
        canvas.height = Math.max(1, Math.round(video.videoHeight * scale));
        const ctx = canvas.getContext('2d');
        if (!ctx) return;
        ctx.drawImage(video, 0, 0, canvas.width, canvas.height);
        const dataUrl = canvas.toDataURL('image/webp', 0.86);
        sessionStorage.setItem(storageKey, dataUrl);
        applyFallback(dataUrl);
      } catch {}
    };

    video.muted = true;
    video.defaultMuted = true;
    video.playsInline = true;
    video.setAttribute('muted', '');
    video.setAttribute('playsinline', '');
    video.setAttribute('webkit-playsinline', '');
    console.log(`[${debugLabel}] init`, {
      source,
      readyState: video.readyState,
      networkState: video.networkState,
    });

    if (video.readyState >= 2) {
      console.log(`[${debugLabel}] ready immediately`);
      captureFrame();
      tryPlay();
    } else {
      video.addEventListener(
        'loadeddata',
        () => {
          console.log(`[${debugLabel}] loadeddata`);
          captureFrame();
          tryPlay();
        },
        { once: true }
      );
    }

    video.addEventListener('canplay', () => {
      console.log(`[${debugLabel}] canplay`);
      tryPlay();
    });
    video.addEventListener('playing', () => {
      console.log(`[${debugLabel}] playing`);
      captureFrame();
    });
    video.addEventListener('error', () => {
      const mediaError = video.error;
      console.log(`[${debugLabel}] error`, mediaError ? mediaError.code : 'unknown');
    });

    window.addEventListener(
      'pageshow',
      () => {
        console.log(`[${debugLabel}] pageshow`);
        tryPlay();
      },
      { passive: true }
    );
  }

  const canHover = window.matchMedia('(hover: hover) and (pointer: fine)').matches;
  if (canHover) {
    const shells = document.querySelectorAll('.showcase-calendar-shell');
    for (const shell of shells) {
      const flow = shell.closest('.showcase-flow');
      const preview = flow?.querySelector('.calendar-preview');
      if (!(preview instanceof HTMLElement)) continue;

      shell.addEventListener('mouseenter', () => {
        preview.classList.add('is-visible');
      });

      shell.addEventListener('mouseleave', () => {
        preview.classList.remove('is-visible');
      });
    }
  }
</script>

