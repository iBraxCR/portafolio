---
import { getCollection, type CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { t, isLocale, type Locale } from '../../../lib/i18n';

export async function getStaticPaths() {
  const projects = await getCollection('projects', ({ data }) => !data.draft);
  return projects.map((entry) => {
    const cleanSlug = entry.data.urlSlug.replace(/^(es|en)-/, '');
    const lang = entry.data.lang;
    return {
      params: { lang, slug: cleanSlug },
      props: { entry },
    };
  });
}

interface Props {
  entry: CollectionEntry<'projects'>;
}

const { entry } = Astro.props;
const { lang: rawLang } = Astro.params;

if (!isLocale(rawLang)) {
  throw new Error(`Invalid locale: ${rawLang}`);
}
const lang: Locale = rawLang;

const { Content } = await entry.render();

// Next project logic
const allInLang = await getCollection('projects', ({ data }) =>
  data.lang === lang && !data.draft
);
allInLang.sort((a, b) => a.data.number - b.data.number);
const currentIdx = allInLang.findIndex((p) => p.data.urlSlug === entry.data.urlSlug);
const nextEntry = allInLang[(currentIdx + 1) % allInLang.length];
const nextSlug = nextEntry.data.urlSlug.replace(/^(es|en)-/, '');
---

<BaseLayout title={entry.data.title} description={entry.data.description} lang={lang}>

  <!-- HERO IMAGE (full width) -->
  <section class="project-hero">
    {entry.data.cover ? (
      <div class="hero-image">
        <Image src={entry.data.cover} alt={entry.data.title} />
      </div>
    ) : (
      <div class="hero-placeholder" />
    )}
  </section>

  <!-- LAYOUT: sidebar metadata + content -->
  <div class="project-layout">

    <!-- SIDEBAR -->
    <aside class="project-sidebar">
      <dl class="meta-list">
        <div class="meta-item">
          <dt>{t('meta.year', lang)}</dt>
          <dd>{entry.data.year}</dd>
        </div>
        <div class="meta-item">
          <dt>{t('meta.role', lang)}</dt>
          <dd>{entry.data.role.join(', ')}</dd>
        </div>
        {entry.data.client && (
          <div class="meta-item">
            <dt>{t('meta.client', lang)}</dt>
            <dd>{entry.data.client}</dd>
          </div>
        )}
        <div class="meta-item">
          <dt>{t('meta.stack', lang)}</dt>
          <dd class="stack-list">
            {entry.data.stack.frontend?.map((s) => <span>{s}</span>)}
            {entry.data.stack.backend?.map((s) => <span>{s}</span>)}
            {entry.data.stack.infra?.map((s) => <span>{s}</span>)}
          </dd>
        </div>
        {entry.data.url && (
          <div class="meta-item">
            <dt>URL</dt>
            <dd>
              <a href={entry.data.url} target="_blank" rel="noopener">
                {t('common.viewProject', lang)}
              </a>
            </dd>
          </div>
        )}
        {entry.data.repo && (
          <div class="meta-item">
            <dt>Repo</dt>
            <dd>
              <a href={entry.data.repo} target="_blank" rel="noopener">
                {t('common.viewCode', lang)}
              </a>
            </dd>
          </div>
        )}
      </dl>
    </aside>

    <!-- CONTENT -->
    <div class="project-content">
      <h1 class="project-title">{entry.data.title}</h1>
      <p class="project-description">{entry.data.description}</p>
      <div class="prose">
        <Content />
      </div>
    </div>

  </div>

  <!-- GALLERY -->
  {entry.data.gallery && entry.data.gallery.length > 0 && (
    <section class="project-gallery">
      <div class="gallery-grid">
        {entry.data.gallery.map((img) => (
          <div class="gallery-item">
            <Image src={img} alt="" />
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- NEXT PROJECT -->
  <section class="next-project">
    <span class="next-label">{t('works.nextProject', lang)}</span>
    <a href={`/${lang}/works/${nextSlug}/`} class="next-link">
      {nextEntry.data.title}
      <span aria-hidden="true">→</span>
    </a>
  </section>

</BaseLayout>

<style>
  /* Hero image */
  .project-hero {
    width: 100%;
  }
  .hero-image {
    aspect-ratio: 16 / 10;
    overflow: hidden;
  }
  .hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero-placeholder {
    aspect-ratio: 16 / 10;
    background: var(--bg-elev);
  }

  /* Layout 2 columnas */
  .project-layout {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 4rem;
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 4rem var(--pad-x);
  }

  @media (max-width: 767px) {
    .project-layout {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }

  /* Sidebar */
  .project-sidebar {
    position: sticky;
    top: 6rem;
    align-self: start;
  }

  .meta-list {
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .meta-item dt {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--fg-subtle);
    margin-bottom: 0.25rem;
  }

  .meta-item dd {
    font-family: var(--font-mono);
    font-size: var(--fs-small);
    color: var(--fg-muted);
    margin: 0;
  }

  .stack-list {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .meta-item a {
    color: var(--fg);
    text-decoration: none;
    border-bottom: 1px solid var(--line);
    transition: border-color var(--dur-fast) var(--ease-out);
  }
  .meta-item a:hover {
    border-color: var(--accent);
  }

  /* Content */
  .project-title {
    font-family: var(--font-serif);
    font-size: var(--fs-h1);
    font-weight: 400;
    letter-spacing: -0.02em;
    margin: 0 0 1.5rem;
  }

  .project-description {
    font-size: 1.125rem;
    color: var(--fg-muted);
    margin: 0 0 3rem;
    line-height: 1.6;
  }

  /* Prose (contenido MDX) */
  .prose {
    max-width: 65ch;
    font-size: var(--fs-body);
    line-height: 1.75;
    color: var(--fg-muted);
  }

  .prose :global(h2) {
    font-family: var(--font-serif);
    font-size: var(--fs-h2);
    font-weight: 400;
    color: var(--fg);
    margin: 2.5rem 0 1rem;
  }

  .prose :global(p) {
    margin: 0 0 1.5rem;
  }

  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.875em;
    color: var(--accent);
    background: var(--bg-elev);
    padding: 0.1em 0.4em;
  }

  /* Gallery */
  .project-gallery {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0 var(--pad-x) 4rem;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  @media (max-width: 767px) {
    .gallery-grid {
      grid-template-columns: 1fr;
    }
  }

  .gallery-item {
    overflow: hidden;
    aspect-ratio: 4 / 3;
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Next project */
  .next-project {
    border-top: 1px solid var(--line);
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 4rem var(--pad-x) 6rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .next-label {
    font-family: var(--font-mono);
    font-size: var(--fs-small);
    color: var(--fg-subtle);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .next-link {
    font-family: var(--font-serif);
    font-size: var(--fs-h2);
    font-weight: 400;
    color: var(--fg);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 1rem;
    transition: color var(--dur-fast) var(--ease-out);
  }
  .next-link:hover {
    color: var(--accent);
  }
</style>
