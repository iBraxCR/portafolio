---
import { getCollection, type CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Meta from '../../../components/Meta.astro';
import { isLocale, type Locale } from '../../../lib/i18n';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  return posts.map((entry) => {
    const cleanSlug = entry.data.urlSlug.replace(/^(es|en)-/, '');
    return {
      params: { lang: entry.data.lang, slug: cleanSlug },
      props: { entry },
    };
  });
}

interface Props {
  entry: CollectionEntry<'posts'>;
}

const { entry } = Astro.props;
const { lang: rawLang } = Astro.params;

if (!isLocale(rawLang)) {
  throw new Error(`Invalid locale: ${rawLang}`);
}
const lang: Locale = rawLang;

const { Content } = await entry.render();

const allInLang = await getCollection('posts', ({ data }) =>
  data.lang === lang && !data.draft
);
allInLang.sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());
const currentIdx = allInLang.findIndex((post) => post.data.urlSlug === entry.data.urlSlug);
const nextEntry = allInLang[(currentIdx + 1) % allInLang.length];
const nextSlug = nextEntry.data.urlSlug.replace(/^(es|en)-/, '');

const copy = {
  es: {
    heroLabel: '07 / Artículo',
    nextLabel: 'Siguiente artículo',
    updatedLabel: 'Actualizado',
    minLabel: 'min de lectura',
  },
  en: {
    heroLabel: '07 / Article',
    nextLabel: 'Next article',
    updatedLabel: 'Updated',
    minLabel: 'min read',
  },
}[lang];

const locale = lang === 'es' ? 'es-CR' : 'en-US';

const categoryLabels: Record<string, { es: string; en: string }> = {
  frontend: { es: 'Frontend', en: 'Frontend' },
  backend: { es: 'Backend', en: 'Backend' },
  devops: { es: 'DevOps', en: 'DevOps' },
  process: { es: 'Proceso', en: 'Process' },
};

function formatCategory(category: string) {
  return categoryLabels[category]?.[lang] ?? category;
}

function formatDate(date: Date) {
  return new Intl.DateTimeFormat(locale, {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  }).format(date);
}
---

<BaseLayout title={entry.data.title} description={entry.data.excerpt} lang={lang}>
  <section class="hero" data-page-hero>
    <div class="hero-head">
      <p class="section-kicker" data-hero-kicker>{copy.heroLabel}</p>
      <Meta
        items={[
          formatCategory(entry.data.category),
          `${entry.data.readingTime} ${copy.minLabel}`,
          formatDate(entry.data.publishedAt),
        ]}
        class="hero-meta"
        data-hero-meta
      />
    </div>

    <div class="hero-grid">
      <div class="hero-copy">
        <h1 data-hero-title>{entry.data.title}</h1>
        <p class="hero-excerpt" data-hero-copy>{entry.data.excerpt}</p>
      </div>

      <aside class="hero-side" data-hero-card>
        <div class="side-card">
          <div class="side-group">
            <p>{lang === 'es' ? 'Publicado' : 'Published'}</p>
            <span>{formatDate(entry.data.publishedAt)}</span>
          </div>

          {entry.data.updatedAt && (
            <div class="side-group">
              <p>{copy.updatedLabel}</p>
              <span>{formatDate(entry.data.updatedAt)}</span>
            </div>
          )}

          {entry.data.tags.length > 0 && (
            <div class="side-group">
              <p>Tags</p>
              <span>{entry.data.tags.join(' · ')}</span>
            </div>
          )}
        </div>
      </aside>
    </div>
  </section>

  {entry.data.cover && (
    <section class="hero-media" data-hero-media>
      <div class="cover-frame" data-parallax="8">
        <Image src={entry.data.cover} alt={entry.data.title} widths={[720, 1080, 1440, 1800]} sizes="100vw" />
      </div>
    </section>
  )}

  <section class="content" data-reveal="fade">
    <div class="content-shell">
      <aside class="content-rail" data-reveal="fade-up">
        <p class="section-kicker">{formatCategory(entry.data.category)}</p>
        <p class="rail-copy">{entry.data.excerpt}</p>
      </aside>

      <article class="prose" data-reveal="fade-up">
        <Content />
      </article>
    </div>
  </section>

  {nextEntry && (
    <section class="next-post">
      <p class="section-kicker" data-reveal="fade-up">{copy.nextLabel}</p>
      <a href={`/${lang}/insights/${nextSlug}/`} class="next-link">
        <span>{nextEntry.data.title}</span>
        <span aria-hidden="true">→</span>
      </a>
    </section>
  )}
</BaseLayout>

<style>
  .hero,
  .hero-media,
  .content,
  .next-post {
    max-width: var(--max-w);
    margin: 0 auto;
    padding-inline: var(--pad-x);
  }

  .hero {
    padding-top: 8rem;
    padding-bottom: 4rem;
  }

  .hero-head {
    display: flex;
    justify-content: space-between;
    gap: 2rem;
  }

  .section-kicker,
  .side-group p {
    margin: 0;
    font-family: var(--font-mono);
    font-size: var(--fs-small);
    color: var(--fg-subtle);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .hero-meta {
    justify-content: flex-end;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(18rem, 0.75fr);
    gap: 4rem;
    align-items: start;
    margin-top: 3rem;
  }

  .hero-copy h1 {
    margin: 0;
    font-family: var(--font-serif);
    font-size: clamp(3.4rem, 7vw, 6.5rem);
    font-weight: 400;
    line-height: 0.9;
    letter-spacing: -0.05em;
  }

  .hero-excerpt,
  .rail-copy,
  .prose {
    color: var(--fg-muted);
  }

  .hero-excerpt {
    margin: 1.5rem 0 0;
    max-width: 40rem;
    font-size: 1.1rem;
    line-height: 1.7;
  }

  .side-card {
    padding: 1.25rem;
    display: grid;
    gap: 1rem;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.018), rgba(255, 255, 255, 0)),
      rgba(10, 10, 10, 0.32);
    border: 1px solid var(--line);
    backdrop-filter: blur(16px);
    position: relative;
  }

  .side-card::before,
  .content-rail::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 3rem;
    height: 1px;
    background: linear-gradient(90deg, var(--accent), transparent);
    opacity: 0.85;
  }

  .side-group {
    display: grid;
    gap: 0.4rem;
  }

  .side-group + .side-group {
    padding-top: 0.9rem;
    border-top: 1px solid var(--line);
  }

  .side-group span {
    color: var(--fg-muted);
    line-height: 1.6;
  }

  .hero-media {
    padding-bottom: 4rem;
  }

  .cover-frame {
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: var(--bg-elev);
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow: 0 1.25rem 2.5rem rgba(0, 0, 0, 0.16);
    position: relative;
  }

  .cover-frame :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: saturate(0.93) contrast(1.03);
  }

  .cover-frame::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.04), transparent 30%, rgba(0, 0, 0, 0.18) 100%),
      linear-gradient(135deg, rgba(239, 226, 200, 0.08), transparent 45%),
      repeating-linear-gradient(0deg, rgba(255, 255, 255, 0.018) 0 1px, transparent 1px 3px);
    z-index: 1;
    pointer-events: none;
  }

  .cover-frame::after {
    content: '';
    position: absolute;
    inset: 0.9rem;
    border: 1px solid rgba(255, 255, 255, 0.12);
    z-index: 1;
    pointer-events: none;
  }

  .content {
    padding-top: 4rem;
    padding-bottom: 4rem;
    border-top: 1px solid var(--line);
  }

  .content-shell {
    display: grid;
    grid-template-columns: minmax(14rem, 0.42fr) minmax(0, 1fr);
    gap: 4rem;
  }

  .content-rail {
    position: sticky;
    top: 6rem;
    align-self: start;
    display: grid;
    gap: 1rem;
    padding: 1.15rem 1.2rem;
    border: 1px solid var(--line);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.016), rgba(255, 255, 255, 0)),
      rgba(10, 10, 10, 0.28);
    backdrop-filter: blur(16px);
  }

  .rail-copy {
    margin: 0;
    line-height: 1.6;
  }

  .prose {
    max-width: 72ch;
    font-size: 1.02rem;
    line-height: 1.86;
  }

  .prose :global(h2) {
    margin: 0 0 1rem;
    padding-top: 2.5rem;
    border-top: 1px solid var(--line);
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4vw, 3.25rem);
    font-weight: 400;
    line-height: 0.95;
    letter-spacing: -0.03em;
    color: var(--fg);
  }

  .prose :global(p) {
    margin: 0 0 1.5rem;
  }

  .prose :global(h2 + p) {
    max-width: 62ch;
  }

  .prose :global(a) {
    color: var(--fg);
    text-decoration: underline;
    text-decoration-color: var(--line);
    text-underline-offset: 0.16em;
  }

  .prose :global(a:hover) {
    color: var(--accent);
  }

  /* code blocks (shiki-generated) */
  .prose :global(pre) {
    position: relative;
    margin: 0 0 2rem;
    padding: 1.5rem 1.75rem;
    background-color: var(--bg-elev) !important;
    border: 1px solid var(--line);
    overflow-x: auto;
    scrollbar-width: thin;
    scrollbar-color: var(--line) transparent;
  }

  .prose :global(pre)::before {
    content: attr(data-language);
    position: absolute;
    top: 0.75rem;
    right: 1rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--fg-subtle);
    opacity: 0.6;
  }

  .prose :global(pre code) {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    line-height: 1.85;
    background: none !important;
    padding: 0;
    color: inherit;
  }

  /* inline code */
  .prose :global(:not(pre) > code) {
    font-family: var(--font-mono);
    font-size: 0.875em;
    color: var(--accent);
    background: var(--bg-elev);
    border: 1px solid var(--line);
    padding: 0.1em 0.4em;
  }

  /* list styles */
  .prose :global(ul),
  .prose :global(ol) {
    margin: 0 0 2rem;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.8rem;
  }

  .prose :global(li) {
    position: relative;
    margin: 0;
    padding: 0.95rem 0 0.95rem 2.65rem;
    line-height: 1.72;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    color: var(--fg-muted);
  }

  .prose :global(ul > li)::first-letter,
  .prose :global(ol > li)::first-letter {
    text-transform: uppercase;
  }

  .prose :global(ul > li)::before {
    content: '✤';
    position: absolute;
    top: 0.92rem;
    left: 0.35rem;
    font-family: var(--font-serif);
    font-size: 0.92rem;
    line-height: 1;
    color: var(--accent);
    opacity: 0.9;
    text-shadow: 0 0 0.8rem rgba(239, 226, 200, 0.1);
  }

  .prose :global(ol) {
    counter-reset: insight-list;
  }

  .prose :global(ol > li) {
    counter-increment: insight-list;
  }

  .prose :global(ol > li)::before {
    content: counter(insight-list, decimal-leading-zero);
    position: absolute;
    top: 0.82rem;
    left: 0;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    color: var(--fg-subtle);
  }

  /* strong / em */
  .prose :global(strong) {
    color: var(--fg);
    font-weight: 600;
  }

  .next-post {
    padding-top: 4rem;
    padding-bottom: 6rem;
    border-top: 1px solid var(--line);
    display: grid;
    gap: 1rem;
  }

  .next-link {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: center;
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4.5vw, 4rem);
    font-weight: 400;
    line-height: 0.95;
    letter-spacing: -0.03em;
    color: var(--fg);
  }

  .next-link:hover {
    color: var(--accent);
  }

  @media (max-width: 959px) {
    .hero-head,
    .hero-grid,
    .content-shell {
      display: grid;
      gap: 1rem;
    }

    .hero-meta {
      justify-content: flex-start;
    }

    .content-rail {
      position: static;
    }
  }

  @media (max-width: 639px) {
    .hero {
      padding-top: 6.5rem;
    }

    .hero-copy h1 {
      font-size: clamp(3rem, 13vw, 4.8rem);
      line-height: 0.92;
    }

    .next-link {
      font-size: clamp(1.9rem, 9vw, 2.8rem);
    }
  }
</style>
