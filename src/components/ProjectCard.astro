---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  title: string;
  slug: string;
  lang: string;
  number: number;
  year: number;
  category: string;
  cover?: ImageMetadata;
  coverHover?: ImageMetadata;
}

const { title, slug, lang, number, year, category, cover, coverHover } = Astro.props;

const formattedNumber = String(number).padStart(2, '0');
const href = `/${lang}/works/${slug}/`;
---

<article class="project-card reveal">
  <a href={href} class="card-link">
    <div class="card-image">
      {cover ? (
        <>
          <Image
            src={cover}
            alt={title}
            class="img-main"
            widths={[400, 800, 1200]}
            sizes="(max-width: 767px) 100vw, 50vw"
          />
          {coverHover && (
            <Image
              src={coverHover}
              alt=""
              class="img-hover"
              widths={[400, 800, 1200]}
              sizes="(max-width: 767px) 100vw, 50vw"
            />
          )}
        </>
      ) : (
        <div class="img-placeholder" />
      )}
    </div>
    <footer class="card-meta">
      <span class="card-number">{formattedNumber}</span>
      <span class="card-category">{category}</span>
      <h3 class="card-title">{title}</h3>
      <span class="card-year">{year}</span>
    </footer>
  </a>
</article>

<style>
  .project-card {
    position: relative;
  }

  .card-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .card-image {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--bg-elev);
  }

  .card-image :global(img) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 400ms var(--ease-out);
  }

  .card-image :global(.img-main) {
    opacity: 1;
  }

  .card-image :global(.img-hover) {
    opacity: 0;
  }

  .project-card:hover .card-image :global(.img-hover) {
    opacity: 1;
  }

  .project-card:hover .card-image :global(.img-main) {
    opacity: 0;
  }

  .img-placeholder {
    position: absolute;
    inset: 0;
    background: var(--bg-elev);
  }

  .card-meta {
    padding: 1.25rem var(--pad-x) 2.5rem;
    display: grid;
    grid-template-columns: auto 1fr;
    grid-template-rows: auto auto auto;
    gap: 0.25rem 1rem;
  }

  .card-number {
    font-family: var(--font-mono);
    font-size: var(--fs-small);
    color: var(--fg-subtle);
    grid-column: 1;
    grid-row: 1;
  }

  .card-category {
    font-family: var(--font-mono);
    font-size: var(--fs-small);
    color: var(--fg-subtle);
    text-align: right;
    grid-column: 2;
    grid-row: 1;
  }

  .card-title {
    font-family: var(--font-serif);
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    font-weight: 400;
    letter-spacing: -0.02em;
    margin: 0;
    grid-column: 1 / -1;
    grid-row: 2;
    color: var(--fg);
  }

  .card-year {
    font-family: var(--font-mono);
    font-size: var(--fs-small);
    color: var(--fg-muted);
    grid-column: 1 / -1;
    grid-row: 3;
    padding-top: 0.25rem;
  }
</style>
