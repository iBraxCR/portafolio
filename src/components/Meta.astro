---
interface Props {
  items: (string | number)[];
  separator?: string;
  class?: string;
  [key: string]: unknown;
}

const { items, separator = '—', class: className = '', ...rest } = Astro.props;
const filtered = items.filter((v) => v !== undefined && v !== null && v !== '');
---

<span class={`meta ${className}`.trim()} {...rest}>
  {filtered.map((item, i) => (
    <>
      {i > 0 && <span class="sep">{separator}</span>}
      <span>{item}</span>
    </>
  ))}
</span>

<style>
  .meta {
    font-family: var(--font-mono);
    font-size: var(--fs-small);
    color: var(--fg);
    letter-spacing: 0.02em;
    text-transform: lowercase;
    display: inline-flex;
    gap: 0.5rem;
    align-items: baseline;
    opacity: 0.82;
  }
  .sep {
    color: var(--accent);
    opacity: 0.5;
  }
</style>
