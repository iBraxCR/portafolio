---
import { t, type Locale } from '../lib/i18n';
import LangSwitcher from './LangSwitcher.astro';
import SystemMark from './SystemMark.astro';

interface Props {
  lang: Locale;
  path: string;
}

const { lang, path } = Astro.props;
const base = `/${lang}`;

const links = [
  { href: `${base}/works/`, label: t('nav.works', lang) },
  { href: `${base}/about/`,  label: t('nav.about', lang) },
  { href: `${base}/insights/`, label: t('nav.insights', lang) },
];
---

<header class="nav" data-site-nav>
  <a href={`${base}/`} class="brand" data-nav-brand>
    <SystemMark compact class="brand-mark" />
    <span>Joschua Barahona</span>
  </a>

  <nav aria-label="Primary">
    <ul>
      {links.map((link) => (
        <li>
          <a
            href={link.href}
            aria-current={path.startsWith(link.href) ? 'page' : undefined}
            data-nav-item
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>

  <div class="nav-actions">
    <a href={`/cv/CV_${lang.toUpperCase()}.pdf`} class="nav-btn" download>
      {t('nav.cv', lang)}
    </a>
    <button class="nav-btn nav-btn--accent" data-copy-email="joschuabarahona15@gmail.com">
      <span data-copy-label>{t('nav.email', lang)}</span>
    </button>
    <LangSwitcher current={lang} path={path} />
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding: 18px var(--pad-x);
    gap: 2rem;
    color: var(--fg);
    background: linear-gradient(180deg, rgba(8, 8, 8, 0.62), rgba(8, 8, 8, 0.26));
    backdrop-filter: blur(18px) saturate(118%);
    -webkit-backdrop-filter: blur(18px) saturate(118%);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-serif);
    font-size: 0.95rem;
    letter-spacing: -0.02em;
    white-space: nowrap;
  }

  .brand :global(.brand-mark) {
    flex: 0 0 auto;
  }

  nav {
    justify-self: center;
  }

  nav ul {
    display: flex;
    gap: 1.6rem;
    list-style: none;
    margin: 0;
    padding: 0;
    font-family: var(--font-mono);
    font-size: var(--fs-small);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  nav a {
    color: var(--fg-muted);
    transition: color var(--dur-fast) var(--ease-out);
  }

  nav a:hover,
  nav a[aria-current='page'] {
    color: var(--fg);
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    justify-self: end;
  }

  .nav-btn {
    display: inline-flex;
    align-items: center;
    height: 2rem;
    padding: 0 0.75rem;
    border: 1px solid var(--line);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.03em;
    color: var(--fg-muted);
    white-space: nowrap;
    transition:
      color var(--dur-fast) var(--ease-out),
      border-color var(--dur-fast) var(--ease-out);
  }

  .nav-btn:hover {
    color: var(--fg);
    border-color: rgba(255, 255, 255, 0.28);
  }

  .nav-btn--accent {
    background: var(--accent);
    border-color: var(--accent);
    color: var(--bg);
  }

  .nav-btn--accent:hover {
    opacity: 0.88;
    color: var(--bg);
    border-color: var(--accent);
  }

  @media (max-width: 767px) {
    .nav {
      grid-template-columns: 1fr auto;
      gap: 1rem;
      padding-block: 16px;
    }

    nav {
      grid-column: 1 / -1;
      justify-self: start;
    }

    nav ul {
      gap: 1rem;
      flex-wrap: wrap;
    }

    .nav-btn:not(.nav-btn--accent) {
      display: none;
    }
  }
</style>

<style is:global>
  .copy-toast {
    position: fixed;
    bottom: 2rem;
    left: 50%;
    translate: -50% 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1.25rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.18);
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.14) 0%,
      rgba(255, 255, 255, 0.07) 100%
    );
    backdrop-filter: blur(24px) saturate(140%);
    -webkit-backdrop-filter: blur(24px) saturate(140%);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.28),
      inset 0 -1px 0 rgba(0, 0, 0, 0.24),
      0 8px 32px rgba(0, 0, 0, 0.48),
      0 2px 8px rgba(0, 0, 0, 0.32);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.02em;
    color: var(--fg);
    white-space: nowrap;
    pointer-events: none;
    opacity: 0;
    transform: translateY(12px) scale(0.96);
    transition:
      opacity 260ms cubic-bezier(0.16, 1, 0.3, 1),
      transform 320ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .copy-toast.is-visible {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  .copy-toast.is-hiding {
    opacity: 0;
    transform: translateY(8px) scale(0.97);
    transition:
      opacity 200ms ease-in,
      transform 200ms ease-in;
  }

  .copy-toast-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    border-radius: 999px;
    background: var(--accent);
    flex-shrink: 0;
  }

  .copy-toast-icon svg {
    width: 0.75rem;
    height: 0.75rem;
    stroke: #0a0a0a;
    stroke-width: 2.5;
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .copy-toast-text {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    line-height: 1.2;
  }

  .copy-toast-label {
    font-size: 0.68rem;
    color: var(--fg-subtle);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .copy-toast-email {
    color: var(--accent);
  }
</style>

<script>
  let toastEl: HTMLElement | null = null;
  let hideTimer: ReturnType<typeof setTimeout> | null = null;

  function getOrCreateToast(): HTMLElement {
    if (toastEl && document.body.contains(toastEl)) return toastEl;

    toastEl = document.createElement('div');
    toastEl.className = 'copy-toast';
    toastEl.setAttribute('role', 'status');
    toastEl.setAttribute('aria-live', 'polite');
    toastEl.innerHTML = `
      <div class="copy-toast-icon">
        <svg viewBox="0 0 12 12"><polyline points="1.5,6.5 4.5,9.5 10.5,3"/></svg>
      </div>
      <div class="copy-toast-text">
        <span class="copy-toast-label">Email copiado</span>
        <span class="copy-toast-email">joschuabarahona15@gmail.com</span>
      </div>
    `;
    document.body.appendChild(toastEl);
    return toastEl;
  }

  function showToast() {
    const toast = getOrCreateToast();
    if (hideTimer) clearTimeout(hideTimer);
    toast.classList.remove('is-hiding');
    requestAnimationFrame(() => {
      requestAnimationFrame(() => toast.classList.add('is-visible'));
    });
    hideTimer = setTimeout(() => {
      toast.classList.add('is-hiding');
      toast.classList.remove('is-visible');
    }, 2800);
  }

  function initCopyEmail() {
    document.querySelectorAll<HTMLButtonElement>('[data-copy-email]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const email = btn.dataset.copyEmail!;
        try {
          await navigator.clipboard.writeText(email);
          showToast();
        } catch {
          window.location.href = `mailto:${email}`;
        }
      });
    });
  }

  initCopyEmail();
  document.addEventListener('astro:page-load', initCopyEmail);
</script>
