---
// no props
---

<button id="back-to-top" aria-label="Volver al inicio" class="back-to-top">
  <div id="btt-metal">
    <div class="btt-outline">
      <svg
        class="btt-icon"
        viewBox="0 0 1024 1024"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
      >
        <path d="M843.968 896a51.072 51.072 0 0 1-51.968-52.032V232H180.032A51.072 51.072 0 0 1 128 180.032c0-29.44 22.528-52.032 52.032-52.032h663.936c29.44 0 52.032 22.528 52.032 52.032v663.936c0 29.44-22.528 52.032-52.032 52.032z"></path>
        <path d="M180.032 896a49.92 49.92 0 0 1-36.48-15.616c-20.736-20.8-20.736-53.76 0-72.832L807.616 143.616c20.864-20.8 53.76-20.8 72.832 0 20.8 20.8 20.8 53.76 0 72.768L216.384 880.384a47.232 47.232 0 0 1-36.352 15.616z"></path>
      </svg>
    </div>
  </div>
</button>

<style>
  .back-to-top {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    z-index: 90;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    opacity: 0;
    pointer-events: none;
    transition: opacity 300ms var(--ease-out), transform 300ms var(--ease-out);
    transform: translateY(8px);
  }

  .back-to-top.visible {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .back-to-top { transition: none; }
  }

  #btt-metal {
    position: relative;
    width: 64px;
    height: 64px;
    border-radius: 50%;
  }

  /* Fondo base — visible antes de que cargue el shader */
  #btt-metal::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(160deg, #3a3a3a, #111);
    border-radius: 50%;
    box-shadow: inset 0 1px 2px rgba(255, 255, 255, 0.2);
  }

  .btt-outline {
    position: absolute;
    inset: 0;
    display: flex;
    justify-content: center;
    align-items: center;
    border-radius: 50%;
    z-index: 2;
  }

  /* Borde conic-gradient con mask */
  .btt-outline::before {
    content: "";
    position: absolute;
    inset: 0;
    padding: 1.5px;
    border-radius: 50%;
    background: conic-gradient(from 180deg, #555, #888, #333, #888, #555);
    -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
    mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    mask-composite: exclude;
    transition: opacity 300ms ease;
  }

  .back-to-top:hover .btt-outline::before {
    background: conic-gradient(from 180deg, #aaa, #fff, #888, #fff, #aaa);
  }

  .btt-icon {
    width: 20px;
    height: 20px;
    fill: rgba(255, 255, 255, 0.7);
    transform: rotate(-45deg);
    position: relative;
    z-index: 3;
    transition: fill 200ms ease;
  }

  .back-to-top:hover .btt-icon {
    fill: #fff;
  }
</style>

<script>
  import { liquidMetalFragmentShader, ShaderMount } from '@paper-design/shaders';

  const container = document.getElementById('btt-metal');
  const btn = document.getElementById('back-to-top');

  // Inicializar shader (solo si el usuario no prefiere reducción de movimiento)
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (container && !prefersReduced) {
    new ShaderMount(container, liquidMetalFragmentShader, {
      u_repetition: 1.5,
      u_softness:   0.5,
      u_shiftRed:   0.3,
      u_shiftBlue:  0.3,
      u_distortion: 0,
      u_contour:    0,
      u_angle:      100,
      u_scale:      1.5,
      u_shape:      1,
      u_offsetX:    0.1,
      u_offsetY:   -0.1,
    }, undefined, 0.6);
  }

  // Mostrar/ocultar según posición de scroll
  const onScroll = () => {
    if (window.scrollY > 300) {
      btn?.classList.add('visible');
    } else {
      btn?.classList.remove('visible');
    }
  };
  window.addEventListener('scroll', onScroll, { passive: true });

  // Click → scroll al top (vía Lenis si está disponible)
  btn?.addEventListener('click', () => {
    const lenis = (window as any).__lenis;
    if (lenis) {
      lenis.scrollTo(0, { duration: 1.5 });
    } else {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }
  });
</script>
