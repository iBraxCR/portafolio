---
import { locales, type Locale, switchLocale } from '../lib/i18n';

interface Props {
  current: Locale;
  path: string;
}

const { current, path } = Astro.props;
const links = locales.map((loc) => ({
  loc,
  href: switchLocale(path, loc),
  isActive: loc === current,
}));
---

<div class="lang-switcher" role="group" aria-label="Language" data-nav-lang>
  {links.map(({ loc, href, isActive }) => (
    <a
      href={href}
      class="lang-option"
      aria-current={isActive ? 'true' : undefined}
      lang={loc}
      data-lang-link
    >
      {loc.toUpperCase()}
    </a>
  ))}
</div>

<style>
  .lang-switcher {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 2px;
    padding: 3px;
    height: 34px;
    box-sizing: border-box;
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: var(--fs-small);
    letter-spacing: 0.06em;
    text-transform: uppercase;

    /* glass fill: brighter than the dark nav */
    background: linear-gradient(
      155deg,
      rgba(255, 255, 255, 0.16) 0%,
      rgba(255, 255, 255, 0.08) 55%,
      rgba(255, 255, 255, 0.05) 100%
    );

    /* reflective edge lighting */
    box-shadow:
      inset 0   1px 0     rgba(255, 255, 255, 0.45),
      inset 0  -1px 0     rgba(0,   0,   0,   0.55),
      inset 1px 0   0     rgba(255, 255, 255, 0.14),
      inset -1px 0  0     rgba(0,   0,   0,   0.18),
      inset 2px 3px 0px -2px rgba(255, 255, 255, 0.26),
      inset -2px -2px 0px -2px rgba(255, 255, 255, 0.18),
      inset -0.3px -1px 4px 0px rgba(0, 0, 0, 0.28),
      inset 0px 3px 4px -2px rgba(0, 0, 0, 0.22),
      0 1px 5px rgba(0, 0, 0, 0.25),
      0 6px 18px rgba(0, 0, 0, 0.18);
  }

  /* sliding glass pill */
  .lang-switcher::after {
    content: '';
    position: absolute;
    left: 3px;
    top: 3px;
    width: 38px;
    height: calc(100% - 6px);
    border-radius: 999px;
    pointer-events: none;
    z-index: 0;

    /* pill is noticeably brighter than container */
    background: linear-gradient(
      155deg,
      rgba(255, 255, 255, 0.28) 0%,
      rgba(255, 255, 255, 0.16) 50%,
      rgba(255, 255, 255, 0.09) 100%
    );

    box-shadow:
      inset 0   1px 0     rgba(255, 255, 255, 0.6),
      inset 0  -1px 0     rgba(0,   0,   0,   0.35),
      inset 1.5px 1px 0px -1px rgba(255, 255, 255, 0.5),
      inset -1.5px -1px 0px -1px rgba(255, 255, 255, 0.3),
      inset -1px 2px 3px -1px rgba(0, 0, 0, 0.24),
      inset 0px -4px 1px -2px rgba(0, 0, 0, 0.14),
      0 2px 6px rgba(0, 0, 0, 0.2);

    transition:
      translate 400ms cubic-bezier(1, 0, 0.4, 1),
      box-shadow 400ms cubic-bezier(1, 0, 0.4, 1);
  }

  /* pill position: ES (1st) */
  .lang-switcher:has([aria-current="true"]:nth-child(1))::after {
    translate: 0 0;
    transform-origin: right center;
    animation: lg-snap 460ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  /* pill position: EN (2nd) */
  .lang-switcher:has([aria-current="true"]:nth-child(2))::after {
    translate: 40px 0;
    transform-origin: left center;
    animation: lg-snap 460ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  @keyframes lg-snap {
    0%   { scale: 1 1; }
    38%  { scale: 1.22 0.9; }
    72%  { scale: 0.96 1.04; }
    100% { scale: 1 1; }
  }

  .lang-option {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 100%;
    border-radius: 999px;
    color: var(--fg);
    opacity: 0.5;
    transition: opacity 180ms var(--ease-out);
  }

  .lang-option:hover {
    opacity: 0.82;
  }

  .lang-option[aria-current="true"] {
    opacity: 1;
    cursor: default;
    pointer-events: none;
  }
</style>

<script>
  function updateActive() {
    const isEs = window.location.pathname.startsWith('/es');
    document.querySelectorAll<HTMLElement>('[data-nav-lang]').forEach((sw) => {
      sw.querySelectorAll<HTMLAnchorElement>('[data-lang-link]').forEach((link) => {
        const active = (isEs && link.getAttribute('lang') === 'es') ||
                       (!isEs && link.getAttribute('lang') === 'en');
        active
          ? link.setAttribute('aria-current', 'true')
          : link.removeAttribute('aria-current');
      });
    });
  }

  updateActive();
  document.addEventListener('astro:page-load', updateActive);
</script>
