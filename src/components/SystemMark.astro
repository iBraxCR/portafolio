---
interface Props {
  class?: string;
  compact?: boolean;
  label?: string;
}

const {
  class: className = '',
  compact = false,
  label = 'JGB monogram',
} = Astro.props;
---

<span class:list={['system-mark', className, { 'is-compact': compact }]} aria-label={label} title={label}>
  <img
    src="/logo.webp"
    srcset="/logo.webp 1x, /logo@2x.webp 2x"
    alt=""
    aria-hidden="true"
    class="mark-img"
  />
</span>

<style>
  .system-mark {
    position: relative;
    display: inline-grid;
    place-items: center;
    width: 2.8rem;
    height: 2.8rem;
    border: 1px solid rgba(255, 255, 255, 0.14);
    background: rgba(10, 10, 10, 0.36);
    backdrop-filter: blur(14px);
    overflow: hidden;
    isolation: isolate;
  }

  .system-mark.is-compact {
    width: 2.4rem;
    height: 2.4rem;
  }

  .mark-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
</style>
