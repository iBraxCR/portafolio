---
interface Props {
  class?: string;
  compact?: boolean;
  label?: string;
}

const {
  class: className = '',
  compact = false,
  label = 'System mark: Sou',
} = Astro.props;
---

<span class:list={['system-mark', className, { 'is-compact': compact }]} aria-label={label} title={label}>
  <span class="glyph-base" aria-hidden="true">創</span>
  <span class="glyph-write" aria-hidden="true">創</span>
</span>

<style>
  .system-mark {
    --mark-size: 1.2rem;
    position: relative;
    display: inline-grid;
    place-items: center;
    width: 1.7rem;
    height: 1.7rem;
    border: 1px solid rgba(255, 255, 255, 0.14);
    background: rgba(10, 10, 10, 0.36);
    backdrop-filter: blur(14px);
    overflow: hidden;
    isolation: isolate;
  }

  .system-mark.is-compact {
    --mark-size: 1rem;
    width: 1.45rem;
    height: 1.45rem;
  }

  .glyph-base,
  .glyph-write {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    font-family: "Noto Serif JP", "Yu Mincho", "Hiragino Mincho ProN", serif;
    font-size: var(--mark-size);
    line-height: 1;
    font-weight: 500;
  }

  .glyph-base {
    color: rgba(245, 241, 233, 0.18);
  }

  .glyph-write {
    color: var(--accent);
    overflow: hidden;
    white-space: nowrap;
    width: 0;
    justify-self: start;
    animation: mark-write 2.1s steps(14, end) 280ms forwards;
  }

  .glyph-write::after {
    content: '';
    position: absolute;
    top: 18%;
    bottom: 18%;
    right: 0;
    width: 1px;
    background: rgba(239, 226, 200, 0.9);
    box-shadow: 0 0 0.4rem rgba(239, 226, 200, 0.18);
    animation:
      mark-caret 0.9s step-end 0s 4,
      mark-caret-fade 0.2s linear 2.15s forwards;
  }

  @keyframes mark-write {
    from {
      width: 0;
    }
    to {
      width: 100%;
    }
  }

  @keyframes mark-caret {
    50% {
      opacity: 0;
    }
  }

  @keyframes mark-caret-fade {
    to {
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .glyph-write {
      width: 100%;
      animation: none;
    }

    .glyph-write::after {
      display: none;
      animation: none;
    }
  }
</style>
